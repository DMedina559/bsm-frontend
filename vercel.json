{
  "framework": "vite",
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "src/bsm_frontend/static",
  "redirects": [
    {
      "source": "/",
      "destination": "/app/?hidden=true",
      "permanent": false
    },
    {
      "source": "/app",
      "missing": [
        {
          "type": "query",
          "key": "hidden"
        }
      ],
      "destination": "/app/?hidden=true",
      "permanent": false
    },
    {
      "source": "/app/",
      "missing": [
        {
          "type": "query",
          "key": "hidden"
        }
      ],
      "destination": "/app/?hidden=true",
      "permanent": false
    }
  ],
  "rewrites": {
    "beforeFiles": [
      {
        "source": "/app/assets/:path*",
        "destination": "/assets/:path*"
      },
      {
        "source": "/app/css/:path*",
        "destination": "/css/:path*"
      },
      {
        "source": "/app/image/:path*",
        "destination": "/image/:path*"
      }
    ],
    "fallback": [
      {
        "source": "/app/:path*",
        "destination": "/index.html"
      }
    ]
  }
}
